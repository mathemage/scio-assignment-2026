# Application settings
# IMPORTANT: Generate a secure SECRET_KEY using:
# python3 -c "import secrets; print(secrets.token_urlsafe(32))"
# Then replace the value below with your generated key
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
ENVIRONMENT=development

# Google OAuth2
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# Database
DATABASE_URL=sqlite:///./student_monitor.db

# CORS
FRONTEND_URL=http://localhost:3000

# Demo features (set to 'true' for development/testing)
# Allows users to change their own role via the /auth/set-role endpoint
DEMO_ALLOW_SELF_ROLE_CHANGE=false
